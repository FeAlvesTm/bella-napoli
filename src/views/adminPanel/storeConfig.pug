    #entrega.tab-panel
      .content-wrapper
        .panel-header
          h3 Logística de Entrega
          p Configure tempo da entrega e taxas de serviço.
        
        .panel-body
     
          .delivery-form-group.mb-8
            .flex-between
              label.stat-label Tempo Médio de Entrega
              span.text-orange.font-mono #{storeConfig.delivery_time || 45} min
            
            .slider-container#delivery-slider
              input(type="hidden" name="delivery_time" value=storeConfig.delivery_time || 45)
              .slider-track
                .slider-range(style=`width: ${((storeConfig.delivery_time || 45) / 120) * 100}%;`)
              .slider-thumb(style=`left: ${((storeConfig.delivery_time || 45) / 120) * 100}%;`)

         
          .delivery-body-container
            .delivery-form-group
              label(for="min-order") Valor Mínimo do Pedido
              .input-wrapper
                span.input-prefix R$
                input#min-order.form-input.pl-10(type="number" value=storeConfig.min_order_value || "45.00")
            
            .delivery-form-group
              label(for="delivery-fee") Taxa de Entrega Base
              .input-wrapper
                span.input-prefix R$
                input#delivery-fee.form-input.pl-10(type="number" name="delivery_fee" value=storeConfig.delivery_fee || "10.00")

          .delivery-options
            .delivery-option.flex-between
              div
                h3 Logística de Entrega
                p Ativar frete grátis para pedidos acima de um valor.
                .input-wrapper(style="margin-top: 10px;")
                  span.input-prefix R$ 
           
                  input.form-input.pl-10(type="number" name="free_delivery_threshold" value=storeConfig.free_delivery_threshold || "100.00" step="0.01")
              label.delivery-switch
                input(type="checkbox" name="free_delivery_active" checked=storeConfig.free_delivery_active)
                span.delivery-slider       
  
    #seguranca.tab-panel
      .content-wrapper
        .panel-header
          h3 Métodos de Pagamento Aceitos
          p Configure quais formas de pagamento estão disponíveis para os clientes.
        
        .panel-body
          .payment-list
       
            .payment-row.flex-between
              .payment-info
                svg.lucide.lucide-credit-card(xmlns="http://www.w3.org" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #9ca3af;")
                  rect(width="20" height="14" x="2" y="5" rx="2")
                  line(x1="2" x2="22" y1="10" y2="10")
                span Cartão de Crédito (Online)
              label.delivery-switch
                input(type="checkbox", name="pay_card" checked=storeConfig.pay_card)
                span.delivery-slider

          
            .payment-row.flex-between
              .payment-info
                span.badge-pix PIX
                span Pagamento via PIX
              label.delivery-switch
                input(type="checkbox", name="pay_pix" checked=storeConfig.pay_pix)
                span.delivery-slider

          
            .payment-row.flex-between
              .payment-info
                svg.lucide.lucide-banknote(xmlns="http://www.w3.org" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #9ca3af;")
                  rect(width="20" height="12" x="2" y="6" rx="2")
                  circle(cx="12" cy="12" r="2")
                  line(x1="6" x2="6" y1="12" y2="12")
                  line(x1="18" x2="18" y1="12" y2="12")
                span Dinheiro (Entrega)
              label.delivery-switch
                input(type="checkbox", name="pay_cash" checked=storeConfig.pay_cash)
                span.delivery-slider    