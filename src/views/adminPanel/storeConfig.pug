extends adminBase 

block specific-css
  link(rel='stylesheet' href='/css/storeConfig.css')

block append scripts
  script(src='/js/storeConfig.js')

block content
  section
    div.settings-header
      div 
        h1 Análises e Relatórios
        p Acompanhe o desempenho detalhado da sua pizzaria em tempo real.
      
      button.btn-store-settings
        i(data-lucide="save")
        span Salvar Alterações  
  
  section.settings-section

  .tabs-navigation
    .tabs-list
      
      button.tab-btn.active(data-target="geral")
        i(data-lucide="store")
        span Geral
      button.tab-btn(data-target="entrega")
        i(data-lucide="truck")
        span Entrega
      button.tab-btn(data-target="seguranca")
        i(data-lucide="shield-check")
        span Segurança

  .tabs-content-container
    #geral.tab-panel.active
      div.content-wrapper
        .general-panel-header
          h3 Dados da Unidade
          p Informações públicas que aparecem no recibo e site.
        
        .panel-body
          
          .general-body-container
            .general-form-group
              label(for="store-name") Nome da Pizzaria
              .input-wrapper
                i(data-lucide="store")
                input#store-name.form-input(type="text" name="store_name" value=storeConfig.store_name || "Bella Napoli Artisanal")
            .general-form-group
              label(for="cnpj") CNPJ
              .input-wrapper
                i(data-lucide="file-text")
                input#cnpj.form-input(type="text" name="cnpj" value=storeConfig.cnpj || "12.345.678/0001-90")

         
          .general-body-container
            .general-form-group
              label(for="phone") Telefone de Contato
              .input-wrapper
                i(data-lucide="phone")
                input#phone.form-input(type="text" name="phone" value=storeConfig.phone || "(11) 98765-4321")
            .general-form-group
              label(for="email") Email Comercial
              .input-wrapper
                i(data-lucide="mail")
                input#email.form-input(type="text" name="email" value=storeConfig.email || "contato@bellanapoli.com")

     
          .general-body-container
            .general-form-group
              label(for="address") Endereço Completo
              .input-wrapper
                i(data-lucide="map-pin")
                input#address.form-input(type="text" name="address" value=storeConfig.store_address || "Av. das Brasas, 123 - Centro, São Paulo - SP")

      .content-wrapper
        .general-panel-header
          h3 Horários da Unidade
          p Informações públicas que aparecem no recibo e site.

        .opening-hours-row
          span.day-name Segunda
          
          .controls-group
         
            .custom-select-wrapper
              input(type="hidden" name="mon_start" value=storeConfig.mon_start || "18:00")
              button.select-trigger(type="button")
                span #{storeConfig.mon_start || "18:00"}
                i(data-lucide="chevron-down")
              ul.select-options-list
                li(data-value="18:00") 18:00
                li(data-value="19:00") 19:00
                li(data-value="20:00") 20:00

            span.separator até

           
            .custom-select-wrapper
              input(type="hidden" name="mon_end" value=storeConfig.mon_end || "23:00")
              button.select-trigger(type="button")
                span #{storeConfig.mon_end || "23:00"}
                i(data-lucide="chevron-down")
              ul.select-options-list
                li(data-value="22:00") 22:00
                li(data-value="23:00") 23:00
                li(data-value="00:00") 00:00

            label.switch
              input(type="checkbox" name="mon_switch" checked=storeConfig.mon_switch)
              span.slider
          
        .opening-hours-row
          span.day-name Terça
          
          .controls-group
    
            .custom-select-wrapper
              input(type="hidden" name="tue_start" value=storeConfig.tue_start || "18:00")
              button.select-trigger(type="button")
                span #{storeConfig.tue_start || "18:00"}
                i(data-lucide="chevron-down")
              ul.select-options-list
                li(data-value="18:00") 18:00
                li(data-value="19:00") 19:00
                li(data-value="20:00") 20:00

            span.separator até

   
            .custom-select-wrapper
              input(type="hidden" name="tue_end" value=storeConfig.tue_end || "23:00")
              button.select-trigger(type="button")
                span #{storeConfig.tue_end || "23:00"}
                i(data-lucide="chevron-down")
              ul.select-options-list
                li(data-value="22:00") 22:00
                li(data-value="23:00") 23:00
                li(data-value="00:00") 00:00

     
            label.switch
