{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "stripe:listen": "stripe listen --forward-to localhost:4000/webhook",
    "server": "nodemon --watch src --watch db -e js,pug src/server.js",
    "browser": "browser-sync start --config bs-config.cjs",
    "dev": "concurrently \"npm run server\" \"npm run browser\" \"npm run stripe:listen\""
  },
